<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Acción de servidor: enviar mail via método Python en payment.transaction -->
    <!-- Por qué: el HTML se construye directamente en Python, sin motor de plantillas -->
    <record id="action_server_payment_notify" model="ir.actions.server">
        <field name="name">Enviar notificación transacción de pago</field>
        <field name="model_id" ref="payment.model_payment_transaction"/>
        <field name="state">code</field>
        <field name="code">records._send_payment_notification()</field>
    </record>

    <!-- Acción automatizada: enviar mail cuando transacción pasa a pending -->
    <!-- Por qué: Corina y Carlos necesitan saber cuando un cliente intenta pagar -->
    <record id="automation_payment_pending_notify" model="base.automation">
        <field name="name">Notificar transacción pendiente</field>
        <field name="model_id" ref="payment.model_payment_transaction"/>
        <field name="trigger">on_state_set</field>
        <field name="trigger_field_ids" eval="[(4, ref('payment.field_payment_transaction__state'))]"/>
        <field name="filter_domain">[('state', '=', 'pending')]</field>
        <field name="action_server_ids" eval="[(4, ref('mosconi_security.action_server_payment_notify'))]"/>
        <field name="active" eval="True"/>
    </record>

    <!-- Acción automatizada: enviar mail cuando transacción pasa a done -->
    <!-- Por qué: Corina y Carlos necesitan saber cuando se confirma un pago -->
    <record id="automation_payment_done_notify" model="base.automation">
        <field name="name">Notificar transacción confirmada</field>
        <field name="model_id" ref="payment.model_payment_transaction"/>
        <field name="trigger">on_state_set</field>
        <field name="trigger_field_ids" eval="[(4, ref('payment.field_payment_transaction__state'))]"/>
        <field name="filter_domain">[('state', '=', 'done')]</field>
        <field name="action_server_ids" eval="[(4, ref('mosconi_security.action_server_payment_notify'))]"/>
        <field name="active" eval="True"/>
    </record>
</odoo>
